{
  "defaultAction": "deny",
  "rules": [
    {
      "type": "hostname",
      "value": "github.com",
      "ports": [{"value": 443, "protocol": "tcp"}],
      "action": "allow"
    },
    {
      "type": "hostname",
      "value": "registry.npmjs.org",
      "ports": [{"value": 443, "protocol": "tcp"}],
      "action": "allow"
    },
    {
      "type": "cidr",
      "value": "8.8.8.8/32",
      "ports": [{"value": 53, "protocol": "udp"}],
      "action": "allow"
    },
    {
      "type": "cidr",
      "value": "8.8.4.4/32",
      "ports": [{"value": 53, "protocol": "udp"}],
      "action": "allow"
    },
    {
      "type": "cidr",
      "value": "192.168.1.0/24",
      "action": "allow"
    },
    {
      "type": "hostname",
      "value": "api.example.com",
      "ports": [{"value": 80, "protocol": "tcp"}, {"value": 443, "protocol": "tcp"}],
      "action": "allow"
    }
  ],
  "sudoLockdown": {
    "enable": false,
    "allowCommands": ["/usr/bin/apt-get", "/usr/bin/docker"]
  }
}
